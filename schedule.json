{
  "timezone": "Africa/Lagos",
  "jobs": [
    {
      "id": "morning-health",
      "name": "Send morning health report",
      "cron": "10 6 * * *",
      "command": "health-check",
      "args": [
        "--notify"
      ]
    },
    {
      "id": "morning-preserve",
      "name": "Preserve battery before morning outage",
      "cron": "30 6 * * *",
      "command": "preserve-battery"
    },
    {
      "id": "morning-return-sbu",
      "name": "Return to SBU before morning outage",
      "cron": "55 7 * * *",
      "command": "return-sbu"
    },
    {
      "id": "morning-watchdog",
      "name": "Verify SBU after morning outage starts",
      "cron": "1 8 * * *",
      "command": "watchdog-sbu"
    },
    {
      "id": "afternoon-preserve",
      "name": "Preserve battery before afternoon outage",
      "cron": "30 14 * * 1-5",
      "command": "preserve-battery"
    },
    {
      "id": "afternoon-return-sbu",
      "name": "Return to SBU before afternoon outage",
      "cron": "25 15 * * 1-5",
      "command": "return-sbu"
    },
    {
      "id": "afternoon-watchdog",
      "name": "Verify SBU after afternoon outage starts",
      "cron": "31 15 * * 1-5",
      "command": "watchdog-sbu"
    },
    {
      "id": "daily-summary",
      "name": "Post daily Discord summary",
      "cron": "0 21 * * *",
      "command": "daily-summary"
    },
    {
      "id": "waste-alert-check",
      "name": "Alert if Utility is on while PV can cover the load",
      "cron": "*/30 7-19 * * *",
      "command": "waste-alert-check"
    },
    {
      "id": "battery-alert",
      "name": "Check emergency battery SOC",
      "cron": "*/30 * * * *",
      "command": "battery-alert"
    },
    {
      "id": "auto-topup-check",
      "name": "Start night topup if battery won't reach sunrise",
      "cron": "*/20 22-23,0-2 * * *",
      "command": "auto-topup-check"
    },
    {
      "id": "topup-complete-check",
      "name": "Resume automation and return to SBU once topup window expires",
      "cron": "*/10 22-23,0-6 * * *",
      "command": "topup-complete-check"
    },
    {
      "id": "weekly-summary",
      "name": "Post weekly performance summary",
      "cron": "10 21 * * 0",
      "command": "weekly-summary"
    },
    {
      "id": "monthly-summary",
      "name": "Post monthly performance summary on the 1st",
      "cron": "10 21 1 * *",
      "command": "monthly-summary"
    },
    {
      "id": "rotate-logs",
      "name": "Rotate old generated logs",
      "cron": "10 0 * * *",
      "command": "rotate-logs"
    },
    {
      "id": "prune-audit",
      "name": "Prune old audit log rows on the 1st of each month",
      "cron": "20 0 1 * *",
      "command": "prune-audit"
    }
  ]
}
