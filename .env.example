# ShinePhone / Growatt credentials.
GROWATT_USERNAME=your_shinephone_username
GROWATT_PASSWORD=your_shinephone_password

# Most ShinePhone accounts outside China/North America use this URL.
# North America: https://openapi-us.growatt.com/
# China: https://openapi-cn.growatt.com/
GROWATT_SERVER_URL=https://openapi.growatt.com/

# Leave blank to auto-select the first plant and first storage/SPF-looking device.
GROWATT_PLANT_ID=
GROWATT_DEVICE_SN=

# Preserve-battery behavior. If SOC is below this before an outage window,
# switch to Utility while estate power is still available.
LOW_BATTERY_SOC=50

# Optional weather-aware threshold. When enabled, rainy/cloudy keeps the
# threshold at LOW_BATTERY_SOC, normal weather uses LOW_BATTERY_SOC_NORMAL,
# and sunny weather uses LOW_BATTERY_SOC_SUNNY.
WEATHER_ENABLED=false
WEATHER_LAT=
WEATHER_LON=
WEATHER_TIMEZONE=Africa/Lagos
WEATHER_LOOKAHEAD_HOURS=4
WEATHER_CLOUDY_THRESHOLD=70
WEATHER_SUNNY_THRESHOLD=35
WEATHER_RAIN_THRESHOLD_MM=1
LOW_BATTERY_SOC_NORMAL=45
LOW_BATTERY_SOC_SUNNY=40

# Emergency read-only battery alert. battery-alert sends Discord once when SOC
# drops below EMERGENCY_SOC, then clears after SOC reaches EMERGENCY_SOC_RECOVERY.
EMERGENCY_SOC=30
EMERGENCY_SOC_RECOVERY=35

# Keep true until status/probe works and you are ready to change inverter settings.
DRY_RUN=true

# SPF 6000 ES PLUS uses Growatt's SPF5000 storage command family.
GROWATT_MODE_DRIVER=spf5000

# Optional custom writer settings. Leave these blank when using
# GROWATT_MODE_DRIVER=spf5000.
#
# Example shape if the server accepts a tcpSet/newTcpset style command:
# GROWATT_SET_MODE_PATH=tcpSet.do
# GROWATT_SET_MODE_METHOD=post
# GROWATT_UTILITY_MODE_PARAMS={"action":"storageSPF5000Set","serialNum":"{device_sn}","type":"storage_spf5000_ac_output_source","param1":"2","param2":"","param3":"","param4":""}
# GROWATT_SBU_MODE_PARAMS={"action":"storageSPF5000Set","serialNum":"{device_sn}","type":"storage_spf5000_ac_output_source","param1":"0","param2":"","param3":"","param4":""}
GROWATT_SET_MODE_PATH=tcpSet.do
GROWATT_SET_MODE_METHOD=post
GROWATT_UTILITY_MODE_PARAMS=
GROWATT_SBU_MODE_PARAMS=

# Optional Discord notifications. Create a Discord channel webhook and paste
# the URL here. Keep this value private.
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_SUCCESS=true
DISCORD_NOTIFY_SKIP=false
DISCORD_NOTIFY_FAILURE=true

# Generated probe files older than this are deleted by rotate-logs.
# growatt_power_guard.log and cron.log are kept as active logs.
LOG_RETENTION_DAYS=30
