# ShinePhone / Growatt credentials.
GROWATT_USERNAME=your_shinephone_username
GROWATT_PASSWORD=your_shinephone_password

# Most ShinePhone accounts outside China/North America use this URL.
# North America: https://openapi-us.growatt.com/
# China: https://openapi-cn.growatt.com/
GROWATT_SERVER_URL=https://openapi.growatt.com/

# Leave blank to auto-select the first plant and first storage/SPF-looking device.
GROWATT_PLANT_ID=
GROWATT_DEVICE_SN=

# Preserve-battery behavior. If SOC is below this before an outage window,
# switch to Utility while estate power is still available.
LOW_BATTERY_SOC=50
# Retry transient Growatt Utility-switch failures before giving up.
PRESERVE_UTILITY_MAX_ATTEMPTS=2
PRESERVE_UTILITY_RETRY_DELAY_SECONDS=30

# Optional weather-aware threshold. When enabled, rainy/cloudy keeps the
# threshold at LOW_BATTERY_SOC, normal weather uses LOW_BATTERY_SOC_NORMAL,
# and sunny weather uses LOW_BATTERY_SOC_SUNNY.
WEATHER_ENABLED=false
WEATHER_LAT=
WEATHER_LON=
WEATHER_TIMEZONE=Africa/Lagos
WEATHER_LOOKAHEAD_HOURS=4
WEATHER_CLOUDY_THRESHOLD=70
WEATHER_SUNNY_THRESHOLD=35
WEATHER_RAIN_THRESHOLD_MM=1
LOW_BATTERY_SOC_NORMAL=45
LOW_BATTERY_SOC_SUNNY=40

# Optional dashboard PV kWh forecast. Open-Meteo supplies irradiance; PANEL_KWP
# lets the dashboard convert that sunlight forecast into expected generation.
# Example: a 4.8 kWp array with normal losses -> PANEL_KWP=4.8.
PANEL_KWP=0
PANEL_PERFORMANCE_RATIO=0.75

# Emergency read-only battery alert. battery-alert sends Discord once when SOC
# drops below EMERGENCY_SOC, then clears after SOC reaches EMERGENCY_SOC_RECOVERY.
# It also alerts up to 3 times when actual grid bypass/AC charging is
# detected above BYPASS_ALERT_SOC, then resets when bypass stops or SOC drops
# to/below it.
EMERGENCY_SOC=30
EMERGENCY_SOC_RECOVERY=35
BYPASS_ALERT_SOC=40

# Keep true until status/probe works and you are ready to change inverter settings.
DRY_RUN=true

# SPF 6000 ES PLUS uses Growatt's SPF5000 storage command family.
GROWATT_MODE_DRIVER=spf5000

# Optional custom writer settings. Leave these blank when using
# GROWATT_MODE_DRIVER=spf5000.
#
# Example shape if the server accepts a tcpSet/newTcpset style command:
# GROWATT_SET_MODE_PATH=tcpSet.do
# GROWATT_SET_MODE_METHOD=post
# GROWATT_UTILITY_MODE_PARAMS={"action":"storageSPF5000Set","serialNum":"{device_sn}","type":"storage_spf5000_ac_output_source","param1":"2","param2":"","param3":"","param4":""}
# GROWATT_SBU_MODE_PARAMS={"action":"storageSPF5000Set","serialNum":"{device_sn}","type":"storage_spf5000_ac_output_source","param1":"0","param2":"","param3":"","param4":""}
GROWATT_SET_MODE_PATH=tcpSet.do
GROWATT_SET_MODE_METHOD=post
GROWATT_UTILITY_MODE_PARAMS=
GROWATT_SBU_MODE_PARAMS=

# Optional Discord notifications. Create a Discord channel webhook and paste
# the URL here. Keep this value private.
DISCORD_WEBHOOK_URL=
DISCORD_NOTIFY_SUCCESS=true
DISCORD_NOTIFY_SKIP=false
DISCORD_NOTIFY_FAILURE=true

# Optional private Discord control bot. This is separate from the webhook above.
# Use a private channel and only allow your own Discord user ID.
DISCORD_BOT_TOKEN=
DISCORD_CONTROL_CHANNEL_ID=
DISCORD_CONTROL_ALLOWED_USER_IDS=
DISCORD_CONTROL_GUILD_ID=
DISCORD_TOPUP_MAX_MINUTES=180

# Only alert after this many consecutive Growatt cloud login/status failures.
GROWATT_CLOUD_FAILURE_ALERT_THRESHOLD=3

# Dashboard freshness badge and stale Discord alert threshold.
DASHBOARD_STALE_MINUTES=30

# Optional PVOutput upload. When enabled, observability-refresh uploads from the
# same Growatt status read used to refresh dashboard.html.
PVOUTPUT_ENABLED=false
PVOUTPUT_API_KEY=
PVOUTPUT_SYSTEM_ID=

# Generated probe/temp files older than this are deleted by rotate-logs.
# growatt_power_guard.log rotates by size in Python; cron.log can be rotated with install_logrotate.sh.
LOG_RETENTION_DAYS=30
# Audit CSV (mode_decisions.csv) rows older than this are removed monthly by prune-audit.
AUDIT_RETENTION_DAYS=90

# Battery bank capacity for runtime estimation. Set to total Wh across all
# batteries (e.g. two 15 kWh packs = 30000). Leave at 0 to disable estimation.
BATTERY_CAPACITY_WH=0
# BMS cutoff SOC % — the inverter shuts off below this level (default 25).
BATTERY_BMS_CUTOFF_SOC=25
# Automatic return-sbu and watchdog repairs stay on Utility below this SOC.
# If SOC cannot be read, the automatic return is also blocked. Set 0 to disable.
# A manual emergency bypass requires: return-sbu --allow-low-soc --reason "..."
MIN_SBU_RETURN_SOC=30
# Charge rate in watts from mains. Used by /growatt_topup target_soc to compute
# duration. Set to your actual charger output (e.g. 3000 for 3 kW). 0 = disabled.
BATTERY_CHARGE_RATE_W=0
# When true, preserve-battery threshold is nudged ±5% based on current load.
# High load (>60%) raises threshold; low load (<20%) lowers it.
LOAD_AWARE_THRESHOLD=false

# Charge ceiling: watchdog-sbu will not repair to SBU until SOC reaches this level.
# Set to e.g. 75 to stop grid-charging once adequately charged. 0 = disabled.
BATTERY_CHARGE_TARGET_SOC=0

# Auto-topup: automatically charge from Utility at night if battery won't last until sunrise.
# Requires BATTERY_CAPACITY_WH, BATTERY_CHARGE_RATE_W, WEATHER_LAT, WEATHER_LON.
AUTO_TOPUP_ENABLED=false
# Only fire auto-topup when sunrise is at least this many hours away. 0 = no cutoff. Default 4.
AUTO_TOPUP_MIN_HOURS_TO_SUNRISE=4
# Skip auto-topup if the calculated charge duration is shorter than this many minutes. 0 = disabled.
AUTO_TOPUP_MIN_MINUTES=0
# Target SOC to have remaining at sunrise. Must be > BATTERY_BMS_CUTOFF_SOC to have effect.
# Example: 35 means "charge enough tonight to arrive at sunrise with 35% SOC remaining".
# 0 = disabled (target defaults to BATTERY_BMS_CUTOFF_SOC, i.e. bare survival).
AUTO_TOPUP_TARGET_SOC=0
# Skip overnight topup if tomorrow's total solar irradiance forecast exceeds this threshold (kWh/m²).
# Requires WEATHER_LAT/WEATHER_LON. Clear Lagos day ≈ 6–7, overcast ≈ 1–2. Suggested: 4.0. 0 = disabled.
AUTO_TOPUP_SOLAR_SKIP_KWH_M2=0
# Sunny-forecast skips are allowed only if battery can reach sunrise plus this runtime margin.
# Default 60. Set 0 for bare survival.
AUTO_TOPUP_SOLAR_SKIP_MIN_MARGIN_MINUTES=60

# Low runtime alert: send Discord alert when estimated runtime drops below this many minutes.
# Requires BATTERY_CAPACITY_WH. 0 = disabled.
RUNTIME_ALERT_MINUTES=0
# Clear the runtime alert when runtime recovers to this many minutes. 0 = 1.5x alert threshold.
RUNTIME_ALERT_CLEAR_MINUTES=0

# Session reuse: cache the Growatt login session and reuse it until shortly
# before this TTL, reducing logins from ~250/day to a handful. Guards against
# Growatt's 24h account lock (msg 507). 0 = disabled (log in on every run).
# Growatt sessions have been observed expiring around 60 minutes, so 60 refreshes
# proactively at about 55 minutes. Concurrent stale-cache refreshes are
# coordinated through a local refresh lock.
GROWATT_SESSION_TTL_MINUTES=0

# BetterStack heartbeat: ping this URL at the end of every health-check run so
# BetterStack can alert you if the VPS goes down or cron stops running entirely.
# Create a heartbeat monitor at betterstack.com with a 25h interval, paste the
# URL here. Leave blank to disable.
BETTERSTACK_HEARTBEAT_URL=
